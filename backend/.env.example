# Server Configuration
NODE_ENV=development
PORT=5000

# PostgreSQL Database
# PRODUCTION: Use 127.0.0.1 instead of localhost to avoid peer authentication issues
# Example: postgresql://postgres:password@127.0.0.1:5432/otoolgunb2b?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/otoolgunb2b?schema=public"

# JWT Secret (generate a random 32+ character string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ERP Configuration
USE_MOCK_ERP=true
ERP_SERVER=
ERP_DATABASE=
ERP_USER=
ERP_PASSWORD=
ERP_PORT=1433
ERP_USER_NO=1

# CORS
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000

# Tenant Resolution
DEFAULT_TENANT_SLUG=otoolgun
TENANT_PLATFORM_DOMAINS=localhost,127.0.0.1
TENANT_OTOOLGUN_DOMAINS=
TARGET_TENANT_SLUG=otoolgun

# Cron Job
ENABLE_CRON=true
SYNC_CRON_SCHEDULE="0 * * * *"
VADE_SYNC_CRON_SCHEDULE="0 * * * *"
VADE_REMINDER_CRON_SCHEDULE="0 * * * *"

# E-Invoice Upload + Auto Import
EINVOICE_UPLOAD_DIR=private-uploads/einvoices
EINVOICE_AUTO_IMPORT_ENABLED=false
EINVOICE_AUTO_IMPORT_CRON_SCHEDULE="*/20 * * * *"
EINVOICE_AUTO_IMPORT_SOURCE_DIR=/var/www/b2b/backend/auto-import/einvoices
EINVOICE_AUTO_IMPORT_ARCHIVE_DIR=/var/www/b2b/backend/auto-import/einvoices/_processed
EINVOICE_AUTO_IMPORT_PREFIXES=DEF26,DAR26
EINVOICE_AUTO_IMPORT_RECURSIVE=true
EINVOICE_AUTO_IMPORT_SKIP_EXISTING=true
EINVOICE_AUTO_IMPORT_DELETE_AFTER_IMPORT=false
EINVOICE_AUTO_IMPORT_MAX_FILES=500
